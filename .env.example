# =============================================================
# PRONOTE+ — Environment configuration
# Copy this file to `.env` and adjust values.
# =============================================================

# Server
PORT=3001
NODE_ENV=development

# JWT signing secret (min 32 chars). REQUIRED in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# AES-256-GCM key for encrypting stored Pronote passwords.
# Must be SEPARATE from JWT_SECRET in production.
# If not set, an ephemeral key is generated at startup — sessions will not survive a restart.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ENCRYPTION_KEY=

# JWT token lifetime (default 7d)
TOKEN_TTL=7d

# Pronote device identifier (any stable UUID-like string)
DEVICE_UUID=pronote-plus-server-v1

# CORS — comma-separated list of allowed origins.
# Leave empty in production for same-origin only.
# Example: CORS_ORIGIN=https://app.example.com,https://app2.example.com
CORS_ORIGIN=

# Allow credentials in CORS requests. DO NOT combine with CORS_ORIGIN=*.
# Only set this if your frontend lives on a different origin AND needs cookies/Authorization headers.
CORS_CREDENTIALS=
