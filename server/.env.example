# Authentification
# OBLIGATOIRE en production. Doit être une chaîne aléatoire de 64+ caractères.
# Génère avec: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=change-me-in-production-please-use-a-long-random-string-here

# Origines autorisées pour CORS (séparées par virgules), ou '*' pour tout autoriser
CORS_ORIGIN=https://pronote-plus.app,https://www.pronote-plus.app

# Identifiant unique de l'appareil (utilisé par Pawnote pour la connexion)
DEVICE_UUID=pronote-plus-server-v1

# Durée de validité des tokens (par défaut 7d)
TOKEN_TTL=7d

# Port (Railway le définit automatiquement)
# PORT=3001

# Environnement
# NODE_ENV=production
