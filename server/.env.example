# Server
PORT=3001
NODE_ENV=development

# JWT signing secret (min 32 chars). REQUIRED in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# AES-256-GCM key for encrypting Pronote passwords in the server session cache.
# Must be separate from JWT_SECRET in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ENCRYPTION_KEY=

# JWT token lifetime (default 7d)
TOKEN_TTL=7d

# Pronote device identifier used by Pawnote
DEVICE_UUID=pronote-plus-server-v1

# CORS allowlist. Leave empty in production for same-origin only.
# Example: CORS_ORIGIN=https://app.example.com,https://app2.example.com
CORS_ORIGIN=

# Do not combine with CORS_ORIGIN=*.
CORS_CREDENTIALS=
